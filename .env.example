DATABASE_URL=sqlite:////data/ocr.db
UPLOAD_DIR=/data/uploads
RESULTS_DIR=/data/results
WATCH_INPUT_DIR=/data/watch_input
WATCH_OUTPUT_DIR=/data/watch_output
APP_BASE_URL=http://localhost:8000

# OpenAI
OPENAI_API_KEY=

# Azure OpenAI / AI Foundry
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# Local LLM via Ollama (OpenAI-compatible)
LOCAL_LLM_BASE_URL=http://host.docker.internal:11434/v1
# OCR / text extraction model
LOCAL_LLM_MODEL=qwen3-vl:8b
# Content classification model (leave empty to use LOCAL_LLM_MODEL)
LOCAL_CLASSIFIER_MODEL=
# Text-only model to strip thinking commentary from vision model output (e.g. qwen3:8b)
LOCAL_CLEANUP_MODEL=

# OCR settings
OCR_CONFIDENCE_THRESHOLD=60
OCR_DPI=300

# Job settings
JOB_RETENTION_DAYS=30

# Folder watcher defaults
WATCH_DEFAULT_MODE=auto
WATCH_DEFAULT_FORMAT=plain
WATCH_DEFAULT_LANGUAGES=eng

# App
APP_VERSION=1.0.0
# If set, this token is required in X-Admin-Token header for key management endpoints
ADMIN_TOKEN=
